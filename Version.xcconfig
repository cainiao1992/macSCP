// Version configuration
// Change version numbers here — all targets and build configurations will pick them up automatically.
// create-dmg.sh reads from xcodebuild, which also uses these values.
//
// CURRENT_PROJECT_VERSION formula: major*10000 + minor*100 + patch*1
// Example: 1.2.0 → 10200, 1.2.1 → 10201, 2.0.0 → 20000

MARKETING_VERSION = 1.3.0
CURRENT_PROJECT_VERSION = 10300
